# Matchfile — Fastlane Match configuration
#
# Match syncs code-signing certificates and provisioning profiles via a private
# encrypted Git repo so CI (and team members) can always get the right cert
# without manually exporting from Keychain.
#
# One-time setup (run on a Mac with Apple Developer access):
#   bundle exec fastlane match appstore
#
# This will:
#   1. Create (or download) the App Store distribution certificate
#   2. Create (or download) the provisioning profile for org.sefaria.sefariaApp
#   3. Encrypt everything and push to the git_url repo below
#
# The MATCH_PASSWORD env var (or GitHub secret) holds the encryption password.

git_url("https://github.com/Sefaria/sefaria-ios-certs")
storage_mode("git")
type("appstore")
app_identifier("org.sefaria.sefariaApp")
username("hello@sefaria.org")
