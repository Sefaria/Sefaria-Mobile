# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight.
        Called by both deploy-ios.yml (QA, no version bump) and
        deploy-ios-release.yml (prod, version_name provided).
        version_name: optional MAJOR.MINOR.PATCH"
  lane :beta do |options|
    api_key = app_store_connect_api_key(
      key_id:       ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id:    ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: "/tmp/AuthKey.p8",
    )

    version_name = options[:version_name]
    if version_name && !version_name.empty?
      UI.user_error!("version_name must be MAJOR.MINOR.PATCH") \
        unless version_name.match?(/\A\d+\.\d+\.\d+\z/)
      increment_version_number(
        version_number: version_name,
        xcodeproj: "./ios/ReaderApp.xcodeproj"
      )
    end

    # Unix timestamp as build number — same pattern as Android QA builds.
    # Always unique and increasing; never committed; no branch conflicts.
    increment_build_number(
      build_number: Time.now.to_i.to_s,
      xcodeproj: "./ios/ReaderApp.xcodeproj"
    )

    sh("../scripts/update_sources.sh")
    sh("cd .. && npm install") unless ENV["CI"]

    build_app(
      scheme:               "ReaderApp",
      workspace:            "./ios/ReaderApp.xcworkspace",
      export_method:        "app-store",
      disable_xcpretty:     true,
    )

    upload_to_testflight(api_key: api_key)
  end
end
